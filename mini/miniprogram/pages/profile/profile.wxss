.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
  color: var(--foreground);
}
.scroll {
  flex: 1;
  height: 0;
}
.profile-shell {
  width: 100%;
  max-width: 720px;
  margin: 0 auto;
  padding: 48rpx var(--content-gutter) 80rpx;
  box-sizing: border-box;
}
.brand-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  background-color: var(--card);
}
.brand-card__mark {
  width: 96rpx;
  height: 96rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background-color: var(--primary);
  color: var(--primary-foreground);
  font-size: var(--font-lg);
  font-weight: 800;
}
.brand-card__copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.brand-card__title {
  color: var(--foreground);
  font-size: var(--font-xl);
  font-weight: 700;
}
.brand-card__subtitle,
.profile-note {
  color: var(--muted-foreground);
  font-size: var(--font-base);
  line-height: 1.5;
}
.feedback {
  width: 100%;
  margin-top: 24rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  background-color: var(--card);
  color: var(--foreground);
  font-size: var(--font-base);
  line-height: 1.4;
}
.feedback::after {
  border-width: 0;
}
.feedback--hover {
  background-color: var(--muted);
  transform: scale(0.99);
}
.info-card {
  margin-top: 24rpx;
  padding: 0 28rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  background-color: var(--card);
}
.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.info-row--last {
  border-bottom-width: 0;
}
.info-row__label,
.info-row__value {
  font-size: var(--font-base);
}
.info-row__value {
  color: var(--muted-foreground);
  text-align: right;
}
.profile-note {
  display: block;
  margin-top: 24rpx;
  padding: 0 8rpx;
}
