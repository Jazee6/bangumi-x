<view class="page {{dark ? 'dark' : ''}}">
  <navigation-bar title="角色" back="{{true}}" dark="{{dark}}" loading="{{loading}}" background="{{dark ? '#0a0a0a' : '#ffffff'}}" color="{{dark ? '#fafafa' : '#18181b'}}" />

  <block wx:if="{{error}}">
    <view class="scroll-placeholder">
      <empty-state title="加载失败" description="网络异常" retry="{{true}}" bindretry="onRetry" />
    </view>
  </block>
  <block wx:elif="{{character}}">
    <scroll-view class="scroll" type="nested" scroll-y show-scrollbar="{{false}}" cache-extent="500">
      <nested-scroll-header>
        <view class="header">
          <view class="header__avatar">
            <proxy-image src="{{character.images.large || character.images.medium}}" mode="aspectFill" />
          </view>
          <view class="header__info">
            <view class="header__title-row">
              <text class="header__name">{{character.name}}</text>
              <image class="header__copy" src="{{copyIcon}}" mode="aspectFit" catchtap="onCopyTitle" />
            </view>
            <view class="header__badges">
              <text wx:if="{{typeLabel}}" class="badge badge--secondary">{{typeLabel}}</text>
              <text wx:if="{{character.gender}}" class="badge">{{character.gender}}</text>
              <text wx:if="{{bloodLabel}}" class="badge">血型 {{bloodLabel}}</text>
              <text wx:if="{{birthday}}" class="badge">{{birthday}}</text>
            </view>
            <text wx:if="{{character.summary}}" class="header__summary" overflow="ellipsis" max-lines="4">{{character.summary}}</text>
          </view>
        </view>
      </nested-scroll-header>

      <nested-scroll-header>
        <view class="tabs">
          <view
            wx:for="{{tabs}}"
            wx:key="value"
            class="tabs__item {{item.value === activeTab ? 'tabs__item--active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onPickTab"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </nested-scroll-header>

      <nested-scroll-body>
        <swiper class="swiper" current="{{activeTab}}" bindchange="onSwiperChange">
          <swiper-item>
            <scroll-view class="tab-scroll" type="custom" scroll-y show-scrollbar="{{false}}" cache-extent="500" associative-container="nested-scroll-view">
              <block wx:if="{{subjectsLoading}}">
                <skeleton type="card" count="{{6}}" />
              </block>
              <block wx:elif="{{subjects.length === 0}}">
                <empty-state title="暂无相关条目" />
              </block>
              <block wx:else>
                <grid-view class="grid" type="aligned" max-cross-axis-extent="140" cross-axis-gap="8" main-axis-gap="12" padding="{{[8, 12, 48, 12]}}">
                  <view wx:for="{{subjects}}" wx:key="id" list-item catchtap="onTapSubject" data-id="{{item.id}}" hover-class="grid__item--hover" hover-stay-time="100">
                    <subject-card
                      name="{{item.name}}"
                      nameCn="{{item.nameCn}}"
                      image="{{item.image}}"
                      score="{{0}}"
                    />
                  </view>
                </grid-view>
              </block>
            </scroll-view>
          </swiper-item>

          <swiper-item>
            <scroll-view class="tab-scroll" type="custom" scroll-y show-scrollbar="{{false}}" cache-extent="500" associative-container="nested-scroll-view">
              <block wx:if="{{personsLoading}}">
                <skeleton type="list" count="{{8}}" />
              </block>
              <block wx:elif="{{persons.length === 0}}">
                <empty-state title="暂无相关人物" />
              </block>
              <block wx:else>
                <view class="cell-list">
                  <view wx:for="{{persons}}" wx:key="id" class="cell-list__item" catchtap="onTapPerson" data-id="{{item.id}}" hover-class="cell-wrap--hover" hover-stay-time="100">
                    <character-cell dark="{{dark}}"
                      title="{{item.title}}"
                      description="{{item.description}}"
                      image="{{item.image}}"
                    />
                  </view>
                </view>
              </block>
            </scroll-view>
          </swiper-item>
        </swiper>
      </nested-scroll-body>
    </scroll-view>
  </block>
  <block wx:else>
    <view class="scroll-placeholder">
      <skeleton wx:if="{{loading}}" type="detail" count="{{1}}" />
      <empty-state wx:else title="暂无数据" />
    </view>
  </block>
</view>
