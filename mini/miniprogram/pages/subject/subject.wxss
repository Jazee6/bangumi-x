.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
  color: var(--foreground);
}
.scroll {
  flex: 1;
  height: 0;
}
.scroll-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 24rpx;
  width: 100%;
  max-width: var(--content-max);
  margin: 0 auto;
  padding: 28rpx var(--content-gutter) 36rpx;
  box-sizing: border-box;
}
.expanded .header {
  gap: 40rpx;
  padding-top: 44rpx;
  padding-bottom: 52rpx;
}
.expanded .header__info {
  max-width: 720px;
}
.header__poster {
  width: 240rpx;
  aspect-ratio: 3 / 4;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: var(--muted);
  flex: none;
}
.expanded .header__poster {
  width: 280rpx;
}
.header__info {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.header__name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--foreground);
}
.header__title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
.header__copy {
  width: 36rpx;
  height: 36rpx;
  flex: none;
  opacity: 0.6;
}
.header__sub-name {
  font-size: var(--font-base);
  color: var(--muted-foreground);
}
.header__badges {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}
.badge {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  color: var(--muted-foreground);
  font-size: var(--font-xs);
}
.badge--secondary {
  background-color: var(--secondary);
  border-color: var(--secondary);
  color: var(--secondary-foreground);
}
.header__summary {
  font-size: var(--font-base);
  line-height: 1.5;
  color: var(--muted-foreground);
}
.header__summary-action {
  align-self: flex-start;
  color: var(--foreground);
  font-size: var(--font-xs);
  font-weight: 600;
}
.header__tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}
.tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background-color: var(--muted);
  color: var(--muted-foreground);
  font-size: var(--font-xs);
}
.tabs {
  display: flex;
  flex-direction: row;
  background-color: var(--background);
  border-bottom: 1rpx solid var(--border);
  width: 100%;
  max-width: var(--content-max);
  margin: 0 auto;
}
.tabs__item {
  position: relative;
  flex: 1;
  height: 48px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--muted-foreground);
  font-size: var(--font-md);
}
.tabs__item--active {
  color: var(--foreground);
  font-weight: 600;
}
.tabs__item--active::after {
  content: "";
  position: absolute;
  left: 32%;
  right: 32%;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background-color: var(--foreground);
}
.swiper {
  height: 100%;
}
.tab-scroll {
  height: 100%;
  width: 100%;
  max-width: var(--content-max);
  margin: 0 auto;
}
.group {
  padding-bottom: 16rpx;
}
.group__title {
  display: block;
  padding: 24rpx 24rpx 16rpx;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--muted-foreground);
}
.loading-more {
  padding: 24rpx 0 48rpx;
  text-align: center;
  color: var(--muted-foreground);
  font-size: var(--font-base);
}
.cell-wrap--hover {
  background-color: var(--muted);
}
