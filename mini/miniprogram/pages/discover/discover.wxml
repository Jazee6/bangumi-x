<view class="page {{dark ? 'dark' : ''}}">
  <navigation-bar title="发现" back="{{false}}" dark="{{dark}}" loading="{{loading}}" background="{{dark ? '#0a0a0a' : '#ffffff'}}" color="{{dark ? '#fafafa' : '#18181b'}}" />

  <view class="search-wrap">
    <search-bar value="{{keyword}}" dark="{{dark}}" placeholder="搜索条目 / 角色 / 人物" bindsearch="onSearch" />
    <view class="tabs-row">
      <view class="tabs">
        <view
          wx:for="{{tabs}}"
          wx:key="value"
          class="tabs__item {{item.value === tab ? 'tabs__item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onPickTab"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
      <picker
        wx:if="{{tab === 'subject'}}"
        class="filter-picker"
        mode="selector"
        range="{{filterOptions}}"
        range-key="label"
        value="{{filterIndex}}"
        bindchange="onPickFilter"
      >
        <view class="filter-picker__trigger"><text>{{currentFilterLabel}}</text><image class="filter-picker__arrow" src="{{chevronDown}}" mode="aspectFit" /></view>
      </picker>
    </view>
  </view>

  <scroll-view class="scroll" type="custom" scroll-y show-scrollbar="{{false}}" cache-extent="500" bindscrolltolower="onLoadMore">
    <block wx:if="{{error}}">
      <empty-state title="加载失败" description="网络异常" retry="{{true}}" bindretry="onRetry" />
    </block>
    <block wx:elif="{{loading && !hasList}}">
      <skeleton type="{{tab === 'subject' ? 'card' : 'list'}}" count="{{6}}" />
    </block>
    <block wx:elif="{{!keyword && tab !== 'subject'}}">
      <empty-state title="输入关键词开始搜索" />
    </block>
    <block wx:elif="{{tab === 'subject'}}">
      <view wx:if="{{subjectList.length === 0}}">
        <empty-state wx:if="{{!loading}}" title="无结果" />
      </view>
      <grid-view wx:else class="grid" type="aligned" max-cross-axis-extent="140" cross-axis-gap="8" main-axis-gap="12" padding="{{[8, 12, 48, 12]}}">
        <navigator wx:for="{{subjectList}}" wx:key="id" list-item url="/pages/subject/subject?id={{item.id}}" hover-class="grid__item--hover" hover-stay-time="100">
          <subject-card
            name="{{item.name}}"
            nameCn="{{item.nameCn}}"
            image="{{item.image}}"
            score="{{item.score}}"
          />
        </navigator>
      </grid-view>
    </block>
    <block wx:elif="{{tab === 'character'}}">
      <view wx:if="{{characterList.length === 0}}">
        <empty-state wx:if="{{!loading}}" title="无结果" />
      </view>
      <list-view wx:else>
        <navigator wx:for="{{characterList}}" wx:key="id" list-item url="/pages/{{item.target}}/{{item.target}}?id={{item.id}}" hover-class="cell-wrap--hover" hover-stay-time="100">
          <character-cell dark="{{dark}}"
            title="{{item.title}}"
            description="{{item.description}}"
            image="{{item.image}}"
          />
        </navigator>
      </list-view>
    </block>
    <block wx:else>
      <view wx:if="{{personList.length === 0}}">
        <empty-state wx:if="{{!loading}}" title="无结果" />
      </view>
      <list-view wx:else>
        <navigator wx:for="{{personList}}" wx:key="id" list-item url="/pages/{{item.target}}/{{item.target}}?id={{item.id}}" hover-class="cell-wrap--hover" hover-stay-time="100">
          <character-cell dark="{{dark}}"
            title="{{item.title}}"
            description="{{item.description}}"
            image="{{item.image}}"
          />
        </navigator>
      </list-view>
    </block>
    <view wx:if="{{loading && hasList}}" class="loading-more">
      <text>加载中...</text>
    </view>
  </scroll-view>
</view>
