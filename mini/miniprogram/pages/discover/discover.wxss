.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
  color: var(--foreground);
}
.search-wrap {
  padding: 16rpx 24rpx 8rpx;
}
.tabs-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
.tabs {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}
.tabs__item {
  flex: none;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background-color: var(--muted);
  color: var(--muted-foreground);
  font-size: 26rpx;
}
.tabs__item--active {
  background-color: var(--primary);
  color: var(--primary-foreground);
}
.filter-picker__trigger {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background-color: var(--muted);
  color: var(--muted-foreground);
  font-size: 26rpx;
}
.filter-picker__arrow {
  width: 20rpx;
  height: 20rpx;
}
.scroll {
  flex: 1;
  height: 0;
}
.loading-more {
  padding: 24rpx 0 48rpx;
  text-align: center;
  color: var(--muted-foreground);
  font-size: 26rpx;
}
.grid__item--hover {
  opacity: 0.85;
}
.cell-wrap--hover {
  background-color: var(--muted);
}
