.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
  color: var(--foreground);
}
.binding-scroll {
  flex: 1;
  height: 0;
}
.binding-shell {
  width: 100%;
  max-width: 720px;
  margin: 0 auto;
  padding: 48rpx var(--content-gutter) 80rpx;
  box-sizing: border-box;
}
.account-card,
.state-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 36rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  background-color: var(--card);
  text-align: center;
}
.account-card__avatar {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  border-radius: 50%;
}
.account-card__fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--muted);
  font-size: var(--font-xl);
  font-weight: 700;
}
.account-card__eyebrow,
.account-card__expiry,
.account-card__notice,
.state-card__description {
  color: var(--muted-foreground);
  font-size: var(--font-base);
}
.account-card__name,
.state-card__title {
  margin-top: 10rpx;
  font-size: var(--font-xl);
  font-weight: 700;
}
.account-card__expiry {
  margin-top: 14rpx;
}
.account-card__notice {
  margin-top: 32rpx;
  line-height: 1.6;
}
.state-card__description {
  margin-top: 16rpx;
  line-height: 1.6;
}
.confirm-button,
.reject-button,
.back-button {
  width: 100%;
  margin-top: 36rpx;
  padding: 22rpx 28rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-base);
  line-height: 1.4;
}
.confirm-button {
  border: 1rpx solid var(--primary);
  background-color: var(--primary);
  color: var(--primary-foreground);
}
.reject-button {
  border: 1rpx solid var(--destructive);
  background-color: var(--card);
  color: var(--destructive);
}
.back-button {
  border: 1rpx solid var(--border);
  background-color: var(--muted);
  color: var(--foreground);
}
.confirm-button::after,
.reject-button::after,
.back-button::after {
  border-width: 0;
}
.confirm-button--hover,
.reject-button--hover,
.back-button--hover {
  opacity: 0.65;
}
