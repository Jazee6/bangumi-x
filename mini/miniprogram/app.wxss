/* 全局主题变量 - 与 web 端 shadcn 中性灰对齐 */
page {
  --background: #ffffff;
  --foreground: #18181b;
  --card: #ffffff;
  --card-foreground: #18181b;
  --primary: #171717;
  --primary-foreground: #ffffff;
  --secondary: #f4f4f5;
  --secondary-foreground: #18181b;
  --muted: #f4f4f5;
  --muted-foreground: #71717a;
  --accent: #f4f4f5;
  --accent-foreground: #18181b;
  --border: #e4e4e7;
  --input: #e4e4e7;
  --radius: 16rpx;
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-base: 26rpx;
  --font-md: 28rpx;
  --font-lg: 30rpx;
  --font-xl: 36rpx;
  background-color: var(--background);
  color: var(--foreground);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-md);
}

page.dark,
.dark {
  --background: #0a0a0a;
  --foreground: #fafafa;
  --card: #18181b;
  --card-foreground: #fafafa;
  --primary: #fafafa;
  --primary-foreground: #0a0a0a;
  --secondary: #27272a;
  --secondary-foreground: #fafafa;
  --muted: #27272a;
  --muted-foreground: #a1a1aa;
  --accent: #27272a;
  --accent-foreground: #fafafa;
  --border: #27272a;
  --input: #27272a;
}

.expanded {
  --font-md: 24rpx;
  --font-lg: 26rpx;
  --font-xl: 30rpx;
}

view,
scroll-view,
text {
  box-sizing: border-box;
}

.app-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
  color: var(--foreground);
}

.app-scroll {
  flex: 1;
  height: 0;
}

.app-padding {
  padding: 24rpx;
}

.muted {
  color: var(--muted-foreground);
}
