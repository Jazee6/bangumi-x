.proxy-image,
.proxy-image__img {
  width: 100%;
  height: 100%;
  display: block;
}
.proxy-image__img {
  pointer-events: none;
}
.proxy-image {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--muted);
  color: var(--muted-foreground);
  pointer-events: none;
}
.proxy-image__placeholder {
  font-size: 24rpx;
}
