.skeleton-cards {
  width: 100%;
  max-width: var(--content-max);
  margin-left: auto;
  margin-right: auto;
}
.skeleton-card {
  display: flex;
  flex-direction: column;
}
.skeleton-card__poster {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: var(--radius-lg);
  background-color: var(--muted);
}
.skeleton-card__line {
  height: 24rpx;
  margin-top: 12rpx;
  border-radius: 8rpx;
  background-color: var(--muted);
}
.skeleton-cells {
  display: flex;
  flex-direction: column;
}
.skeleton-cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background-color: var(--card);
  border-bottom: 1rpx solid var(--border);
}
.skeleton-cell__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--muted);
  flex: none;
}
.skeleton-cell__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.skeleton-cell__line {
  height: 24rpx;
  border-radius: 8rpx;
  background-color: var(--muted);
}
.skeleton-cell__line--short {
  width: 50%;
}
.skeleton-cell__line--shorter {
  width: 30%;
}
.skeleton-detail {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}
.skeleton-detail__poster {
  width: 240rpx;
  aspect-ratio: 3 / 4;
  border-radius: var(--radius);
  background-color: var(--muted);
}
.skeleton-detail__info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.skeleton-detail__line {
  height: 28rpx;
  border-radius: 8rpx;
  background-color: var(--muted);
}
.skeleton-detail__line--title {
  height: 40rpx;
  width: 70%;
}
.skeleton-detail__line--short {
  width: 45%;
}
.shimmer {
  position: relative;
  overflow: hidden;
}
.shimmer::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.25) 50%, rgba(255,255,255,0) 100%);
  animation-name: shimmer;
  animation-duration: 1.4s;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
}
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}
