.subject-card {
  display: flex;
  flex-direction: column;
}
.subject-card__poster {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: var(--muted);
}
.subject-card__score {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.68);
  color: #fff;
  font-size: var(--font-xs);
}
.subject-card__name {
  margin-top: 14rpx;
  font-size: var(--font-base);
  line-height: 1.35;
  font-weight: 600;
  color: var(--foreground);
}
.expanded .subject-card__score {
  top: 8px;
  right: 8px;
  padding: 3px 8px;
}
.expanded .subject-card__name {
  margin-top: 9px;
}
