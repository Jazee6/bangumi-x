.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 24rpx;
  background-color: var(--muted);
  border: 1rpx solid transparent;
  border-radius: 999rpx;
}
.search-bar__icon {
  width: 36rpx;
  height: 36rpx;
  flex: none;
  pointer-events: none;
}
.search-bar__input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--foreground);
}
.search-bar__placeholder {
  color: var(--muted-foreground);
}
.search-bar__clear {
  color: var(--muted-foreground);
  font-size: var(--font-xl);
  line-height: 1;
  padding: 0 8rpx;
}
