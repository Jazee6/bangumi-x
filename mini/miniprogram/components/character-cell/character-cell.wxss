.cell {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  background-color: var(--card);
  border-bottom: 1rpx solid var(--border);
}
.cell__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: var(--muted);
  flex: none;
}
.cell__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.cell__title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--card-foreground);
}
.cell__desc {
  font-size: var(--font-sm);
  color: var(--muted-foreground);
}
.cell__arrow {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
}
.cell__arrow-icon {
  width: 24rpx;
  height: 24rpx;
}
